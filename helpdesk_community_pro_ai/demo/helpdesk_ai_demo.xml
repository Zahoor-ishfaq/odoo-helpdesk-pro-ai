<?xml version="1.0" encoding="utf-8"?>
<!-- Demo data (§11 M6): two AI-enabled teams and eight tickets that
     already show Smart Triage, Sentiment Detection, and the Reply
     Assistant in action, so installing with demo data tells the
     whole story immediately, without waiting for a real API key or
     the sentiment cron to run. Saudi business context, matching the
     other Helpdesk Pro modules' demo data. -->
<odoo>
    <record id="base.user_admin" model="res.users">
        <field name="group_ids" eval="[(4, ref('helpdesk_community_pro.group_helpdesk_manager'))]"/>
    </record>

    <record id="demo_tag_account" model="helpdesk.tag">
        <field name="name">Account</field>
    </record>
    <record id="demo_tag_billing" model="helpdesk.tag">
        <field name="name">Billing</field>
    </record>
    <record id="demo_tag_api" model="helpdesk.tag">
        <field name="name">API</field>
    </record>
    <record id="demo_tag_bug" model="helpdesk.tag">
        <field name="name">Bug</field>
    </record>

    <record id="demo_ai_team_riyadh" model="helpdesk.team">
        <field name="name">Riyadh Customer Care</field>
        <field name="ai_enabled">True</field>
        <field name="ai_auto_apply_threshold">0.85</field>
        <field name="member_ids" eval="[(4, ref('base.user_admin'))]"/>
    </record>
    <record id="demo_ai_team_jeddah" model="helpdesk.team">
        <field name="name">Jeddah Technical Support</field>
        <field name="ai_enabled">True</field>
        <field name="ai_auto_apply_threshold">0.85</field>
        <field name="member_ids" eval="[(4, ref('base.user_admin'))]"/>
    </record>

    <record id="demo_ai_partner_mohammed" model="res.partner">
        <field name="name">Mohammed Al-Otaibi</field>
        <field name="email">mohammed.otaibi@example.sa</field>
        <field name="city">Riyadh</field>
    </record>
    <record id="demo_ai_partner_fatima" model="res.partner">
        <field name="name">Fatima Al-Zahrani</field>
        <field name="email">fatima.zahrani@example.sa</field>
