    <!-- 1. Riyadh Customer Care: high confidence, auto-applied, frustrated -->
    <record id="demo_ai_ticket_login" model="helpdesk.ticket">
        <field name="name">Cannot access my account after password reset</field>
        <field name="team_id" ref="demo_ai_team_riyadh"/>
        <field name="stage_id" ref="helpdesk_community_pro.stage_new"/>
        <field name="partner_id" ref="demo_ai_partner_mohammed"/>
        <field name="partner_email">mohammed.otaibi@example.sa</field>
        <field name="priority">2</field>
        <field name="tag_ids" eval="[(6, 0, [ref('demo_tag_account')])]"/>
        <field name="description" type="html">
<p>I reset my password twice now and I still can't log in -- it keeps saying "invalid credentials". This is blocking my whole team.</p>
        </field>
        <field name="ai_triage_done">True</field>
        <field name="ai_triage_accepted">True</field>
        <field name="ai_triage_team_suggestion">Riyadh Customer Care</field>
        <field name="ai_triage_priority_suggestion">high</field>
        <field name="ai_triage_confidence">0.93</field>
        <field name="ai_sentiment">frustrated</field>
        <field name="ai_sentiment_updated" eval="DateTime.now() - relativedelta(hours=3)"/>
    </record>

    <!-- 2. Riyadh Customer Care: low confidence banner, angry, escalated -->
    <record id="demo_ai_ticket_refund" model="helpdesk.ticket">
        <field name="name">متى سيتم استرداد المبلغ المدفوع؟</field>
        <field name="team_id" ref="demo_ai_team_riyadh"/>
        <field name="stage_id" ref="helpdesk_community_pro.stage_new"/>
        <field name="partner_id" ref="demo_ai_partner_fatima"/>
        <field name="partner_email">fatima.zahrani@example.sa</field>
        <field name="priority">3</field>
        <field name="description" type="html">
<p>طلبت استرداد المبلغ منذ عشرة أيام ولم يصلني شيء حتى الآن. هذا غير مقبول إطلاقاً وأريد حلاً فورياً.</p>
        </field>
        <field name="ai_triage_done">True</field>
        <field name="ai_triage_accepted">False</field>
        <field name="ai_triage_team_suggestion">Riyadh Customer Care</field>
        <field name="ai_triage_priority_suggestion">urgent</field>
        <field name="ai_triage_confidence">0.62</field>
        <field name="ai_sentiment">angry</field>
        <field name="ai_sentiment_updated" eval="DateTime.now() - relativedelta(hours=1)"/>
    </record>
    <record id="demo_ai_activity_refund" model="mail.activity">
        <field name="res_model_id" ref="helpdesk_community_pro.model_helpdesk_ticket"/>
        <field name="res_id" ref="demo_ai_ticket_refund"/>
        <field name="activity_type_id" ref="mail.mail_activity_data_todo"/>
        <field name="summary">Customer sentiment: Angry — review recommended</field>
        <field name="user_id" ref="base.user_admin"/>
    </record>

    <!-- 3. Riyadh Customer Care: high confidence, auto-applied, calm,
         reply draft already generated and staged in the chatter -->
    <record id="demo_ai_ticket_billing" model="helpdesk.ticket">
        <field name="name">Quick question about this month's invoice</field>
        <field name="team_id" ref="demo_ai_team_riyadh"/>
        <field name="stage_id" ref="helpdesk_community_pro.stage_in_progress"/>
        <field name="partner_id" ref="demo_ai_partner_khalid"/>
        <field name="partner_email">khalid.harbi@example.sa</field>
        <field name="user_id" ref="base.user_admin"/>
        <field name="priority">1</field>
        <field name="tag_ids" eval="[(6, 0, [ref('demo_tag_billing')])]"/>
        <field name="description" type="html">
<p>The total on this invoice looks a little higher than last month -- could you confirm what changed? No rush, just curious.</p>
        </field>
        <field name="ai_triage_done">True</field>
        <field name="ai_triage_accepted">True</field>
        <field name="ai_triage_team_suggestion">Riyadh Customer Care</field>
        <field name="ai_triage_priority_suggestion">normal</field>
        <field name="ai_triage_confidence">0.91</field>
        <field name="ai_sentiment">calm</field>
        <field name="ai_sentiment_updated" eval="DateTime.now() - relativedelta(days=1)"/>
    </record>
    <record id="demo_ai_note_billing" model="mail.message">
        <field name="model">helpdesk.ticket</field>
        <field name="res_id" ref="demo_ai_ticket_billing"/>
        <field name="message_type">comment</field>
        <field name="subtype_id" ref="mail.mt_note"/>
        <field name="author_id" ref="base.partner_admin"/>
        <field name="subject">AI drafted reply (copy into your response)</field>
        <field name="body" type="html">
<p>Hi Khalid, thanks for flagging this! The increase is from a prorated add-on charge that started mid-cycle last month -- it'll settle back to the usual amount from next month onward. Happy to walk through the full breakdown if that would help.</p>
        </field>
    </record>

