<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="helpdesk_ai_log_view_list" model="ir.ui.view">
        <field name="name">helpdesk.ai.log.list</field>
        <field name="model">helpdesk.ai.log</field>
        <field name="arch" type="xml">
            <list string="AI Usage Log" create="0" edit="0" delete="0">
                <field name="created_at"/>
                <field name="ticket_id"/>
                <field name="call_type"/>
                <field name="model_used" optional="show"/>
                <field name="total_tokens" sum="Total Tokens"/>
                <field name="cost_estimate" sum="Total Cost" optional="show"/>
                <field name="was_accepted" optional="show"/>
                <field name="sentiment_score" optional="hide"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </list>
        </field>
    </record>

    <record id="helpdesk_ai_log_view_search" model="ir.ui.view">
        <field name="name">helpdesk.ai.log.search</field>
        <field name="model">helpdesk.ai.log</field>
        <field name="arch" type="xml">
            <search string="AI Usage Log">
                <field name="ticket_id"/>
                <field name="model_used"/>
                <filter string="Triage" name="filter_triage" domain="[('call_type', '=', 'triage')]"/>
                <filter string="Sentiment" name="filter_sentiment" domain="[('call_type', '=', 'sentiment')]"/>
                <filter string="Reply Draft" name="filter_reply_draft" domain="[('call_type', '=', 'reply_draft')]"/>
                <separator/>
                <filter string="Accepted" name="filter_accepted" domain="[('was_accepted', '=', True)]"/>
                <filter string="Dismissed" name="filter_dismissed" domain="[('was_accepted', '=', False)]"/>
                <separator/>
                <!-- PORT-19: search-view <group> no longer accepts <filter> children
                     (RNG schema only allows <field> inside it), so these group-by
                     filters are flat siblings instead of wrapped in
                     <group expand="0" string="Group By"> (matches
                     helpdesk_community_pro/views/helpdesk_ticket_views.xml). -->
                <filter string="Call Type" name="group_by_call_type" context="{'group_by': 'call_type'}"/>
                <filter string="Model" name="group_by_model" context="{'group_by': 'model_used'}"/>
            </search>
        </field>
    </record>

    <record id="helpdesk_ai_log_action" model="ir.actions.act_window">
        <field name="name">AI Usage Log</field>
        <field name="res_model">helpdesk.ai.log</field>
        <field name="view_mode">list</field>
        <field name="search_view_id" ref="helpdesk_ai_log_view_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No AI calls logged yet
            </p>
            <p>
                Every Smart Triage, Sentiment, or Reply Draft call Claude
                makes is logged here — never the raw prompt or response,
                only token counts and a short summary.
            </p>
        </field>
    </record>
</odoo>
