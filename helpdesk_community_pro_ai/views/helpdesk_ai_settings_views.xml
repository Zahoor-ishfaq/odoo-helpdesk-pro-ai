<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.helpdesk.ai</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app
                    data-string="Helpdesk AI"
                    string="Helpdesk AI"
                    name="helpdesk_community_pro_ai"
                    groups="base.group_system"
                >
                    <block title="Anthropic API">
                        <setting
                            id="anthropic_api_key_setting"
                            string="Anthropic API Key"
                            help="Paste a new key to replace the stored one. Leave blank to keep the current key unchanged."
                        >
                            <span
                                class="fa fa-check-circle text-success ms-2"
                                title="A key is currently stored"
                                invisible="not anthropic_api_key_configured"
                            />
                            <span
                                class="text-muted ms-2"
                                invisible="anthropic_api_key_configured"
                            >No key stored yet</span>
                            <div class="content-group">
                                <field
                                    name="anthropic_api_key"
                                    password="True"
                                    placeholder="sk-ant-..."
                                    class="o_light_label"
                                />
                            </div>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>
</odoo>
